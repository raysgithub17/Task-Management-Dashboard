# Hugging Face access token (Settings → Access Tokens → enable “Make calls to Inference Providers”).
# Used only by the Vite dev server proxy — never bundled into the client.
HF_ACCESS_TOKEN=

# Optional: defaults to openai/gpt-oss-120b:preferred, then tries other chat models automatically
# VITE_HF_CHAT_MODEL=my-org/MyModel:groq
